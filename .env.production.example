# Ejemplo para compilación de producción (`npm run build`).
# Copia a `.env.production` o `.env.production.local` y rellena los valores.
# La URL de recuperación debe coincidir con un dominio en
# Firebase → Authentication → Settings → Authorized domains (https + ruta /login).

VUE_APP_FIREBASE_API_KEY=
VUE_APP_FIREBASE_AUTH_DOMAIN=
VUE_APP_FIREBASE_PROJECT_ID=
VUE_APP_FIREBASE_STORAGE_BUCKET=
VUE_APP_FIREBASE_MESSAGING_SENDER_ID=
VUE_APP_FIREBASE_APP_ID=

# Recomendada en producción: misma URL de login para todos los usuarios (evita auth/unauthorized-continue-uri).
VUE_APP_PASSWORD_RESET_CONTINUE_URL=https://tu-dominio-o-proyecto.web.app/login
